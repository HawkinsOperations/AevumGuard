{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hawkinsoperations.dev/hoxline/schemas/proofcard-v1.schema.json",
  "title": "Hoxline ProofCard v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "proofcard_id", "detection_id", "artifact_id", "proof_owner", "proof_ceiling", "proof_ceiling_meaning", "review_lane", "review_version", "privacy_review", "stale_review", "evidence_linkage_review", "wording_approval", "public_safe", "public_safe_status", "runtime_active", "signal_observed", "human_review_required", "allowed_claims", "blocked_claims", "promotion_blockers", "proof_packet_reference", "platform_contract_reference", "last_reviewed_at", "missing_evidence", "next_gate"],
  "properties": {
    "schema_version": { "const": "proofcard-v1" },
    "proofcard_id": { "type": "string" },
    "detection_id": { "type": "string" },
    "artifact_id": { "type": "string" },
    "proof_owner": { "type": "string" },
    "proof_ceiling": { "const": "CONTROLLED_TEST_VALIDATED" },
    "proof_ceiling_meaning": { "const": "CONTROLLED_VALIDATION_ONLY" },
    "review_lane": { "const": "PUBLIC_SAFE_CANDIDATE_REVIEW_V1" },
    "review_version": { "const": "v1" },
    "privacy_review": { "const": "PENDING" },
    "stale_review": { "const": "PENDING" },
    "evidence_linkage_review": { "const": "PENDING" },
    "wording_approval": { "const": "PENDING" },
    "public_safe": { "const": false },
    "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
    "runtime_active": { "const": false },
    "signal_observed": { "const": false },
    "human_review_required": { "const": true },
    "allowed_claims": { "type": "array", "items": { "type": "string" } },
    "blocked_claims": { "type": "array" },
    "promotion_blockers": { "type": "array", "items": { "type": "string" }, "minItems": 6 },
    "proof_packet_reference": { "type": "object" },
    "platform_contract_reference": { "type": "object" },
    "last_reviewed_at": { "type": "string", "minLength": 1 },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "next_gate": { "type": "string" }
  }
}
